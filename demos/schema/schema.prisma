generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model users {
  id        Int     @id @default(autoincrement())
  email     String  @unique
  name      String?
  role      Role    @default(USER)
  isActive  Boolean @default(true)
  posts     posts[]
  profile   profile?

  @@index([email])
  @@index([role, isActive])
}

model profile {
  id     Int    @id @default(autoincrement())
  bio    String?
  userId Int    @unique
  user   users  @relation(fields: [userId], references: [id])
}

model posts {
  id          Int      @id @default(autoincrement())
  title       String
  content     String?
  published   Boolean  @default(false)
  authorId    Int
  author      users    @relation(fields: [authorId], references: [id])
  categoryId  Int?
  category    categories? @relation(fields: [categoryId], references: [id])

  @@index([authorId])
}

model categories {
  id       Int    @id @default(autoincrement())
  name     String @unique
  isActive Boolean @default(true)
  posts    posts[]
}

enum Role {
  USER
  ADMIN
  MODERATOR
}
